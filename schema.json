{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/tokipona-pedagogy.schema.json",
  "title": "TokiPonaPedagogySample",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sample_id",
    "lesson",
    "language",
    "messages",
    "pedagogy",
    "quality"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "sample_id": {
      "type": "string",
      "pattern": "^L[0-9]{3}_[0-9]{4}$"
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lesson_id",
        "lesson_type",
        "level",
        "topic",
        "objective"
      ],
      "properties": {
        "lesson_id": {
          "type": "string",
          "pattern": "^L[0-9]{3}$"
        },
        "lesson_type": {
          "type": "string",
          "enum": [
            "guided_dialogue",
            "micro_explanation",
            "pattern_drill",
            "error_correction",
            "review_recap",
            "controlled_composition",
            "translation_with_explanation"
          ]
        },
        "level": {
          "type": "string",
          "enum": ["A0", "A1", "A2", "B1"]
        },
        "topic": {
          "type": "string",
          "minLength": 3,
          "maxLength": 80
        },
        "objective": {
          "type": "string",
          "minLength": 10,
          "maxLength": 240
        }
      }
    },
    "language": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_language", "target_language"],
      "properties": {
        "source_language": {
          "type": "string",
          "const": "fr"
        },
        "target_language": {
          "type": "string",
          "const": "tok"
        }
      }
    },
    "messages": {
      "type": "array",
      "minItems": 3,
      "maxItems": 14,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          }
        }
      },
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "role": {
                "const": "system"
              }
            },
            "required": ["role"]
          },
          "minContains": 1,
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "role": {
                "const": "user"
              }
            },
            "required": ["role"]
          },
          "minContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "role": {
                "const": "assistant"
              }
            },
            "required": ["role"]
          },
          "minContains": 1
        }
      ]
    },
    "pedagogy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skills",
        "difficulty",
        "expects_student_production",
        "includes_correction",
        "includes_recap"
      ],
      "properties": {
        "skills": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": [
              "pronoms",
              "li",
              "e",
              "ordre_des_mots",
              "negation",
              "questions",
              "prepositions",
              "vocabulaire_de_base",
              "reformulation",
              "correction"
            ]
          },
          "uniqueItems": true
        },
        "difficulty": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "expects_student_production": {
          "type": "boolean"
        },
        "includes_correction": {
          "type": "boolean"
        },
        "includes_recap": {
          "type": "boolean"
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safe_for_beginners",
        "no_vulgarity",
        "no_hate",
        "max_new_concepts"
      ],
      "properties": {
        "safe_for_beginners": {
          "type": "boolean",
          "const": true
        },
        "no_vulgarity": {
          "type": "boolean",
          "const": true
        },
        "no_hate": {
          "type": "boolean",
          "const": true
        },
        "max_new_concepts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        }
      }
    }
  }
}
